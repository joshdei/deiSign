            cursor: grabbing;
            transform: scale(1.05);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.2);
        }
        
        .draggable.dragging {
            opacity: 0.8;
            z-index: 1000;
        }
        
        .drop-area {
            position: relative;
            min-height: 600px;
        }
        
        .dropped-item {
            position: absolute;
            cursor: move;
            user-select: none;
            background-color: transparent !important;
        }
        
        .dropped-signature {
            border: 1px dashed transparent;
            padding: 5px;
            border-radius: 4px;
        }
        
        .dropped-date {
            border: 1px dashed transparent;
            padding: 5px;
            border-radius: 4px;
            font-weight: 500;
        }
        
        .delete-btn {
            position: absolute;
            top: -8px;
            right: -8px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #ef4444;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
            opacity: 0;
            transition: opacity 0.2s;
        }
        
        .dropped-item:hover .delete-btn {
