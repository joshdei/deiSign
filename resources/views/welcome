    <script>
        // Mobile menu functionality
        const mobileMenuButton = document.getElementById('mobileMenuButton');
        const closeMenuButton = document.getElementById('closeMenuButton');
        const mobileMenu = document.getElementById('mobileMenu');
        const backdrop = document.getElementById('backdrop');
        
        function openMobileMenu() {
            mobileMenu.classList.add('active');
            backdrop.classList.add('active');
            document.body.style.overflow = 'hidden';
        }
        
        function closeMobileMenu() {
            mobileMenu.classList.remove('active');
            backdrop.classList.remove('active');
            document.body.style.overflow = 'auto';
        }
        
        mobileMenuButton.addEventListener('click', openMobileMenu);
        closeMenuButton.addEventListener('click', closeMobileMenu);
        backdrop.addEventListener('click', closeMobileMenu);
        
        // Close mobile menu when clicking on a menu item
        const mobileMenuItems = document.querySelectorAll('#mobileMenu a');
        mobileMenuItems.forEach(item => {
            item.addEventListener('click', closeMobileMenu);
        });
        
        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                
                const targetId = this.getAttribute('href');
                if (targetId === '#') return;
                
                const targetElement = document.querySelector(targetId);
                if (targetElement) {
                    window.scrollTo({
                        top: targetElement.offsetTop - 80,
                        behavior: 'smooth'
                    });
                }
            });
        });

        // Signature functionality
        const canvas = document.getElementById('signatureCanvas');
        const ctx = canvas.getContext('2d');
        let isDrawing = false;
        let lastX = 0;
        let lastY = 0;
        
        // Set canvas size properly
        function resizeCanvas() {
            const rect = canvas.getBoundingClientRect();
            const dpr = window.devicePixelRatio || 1;
            
            canvas.width = rect.width * dpr;
            canvas.height = rect.height * dpr;
            
            ctx.scale(dpr, dpr);
            
            // Set line properties
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';
            ctx.strokeStyle = '#000';
            
            // Clear with white background
            ctx.fillStyle = '#f8fafc';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
        }
        
        // Initialize canvas
        resizeCanvas();
        window.addEventListener('resize', resizeCanvas);
        
        // Drawing functions
        function startDrawing(e) {
            isDrawing = true;
            [lastX, lastY] = getCoordinates(e);
        }
        
        function draw(e) {
            if (!isDrawing) return;
            
            e.preventDefault();
            
            const [x, y] = getCoordinates(e);
            
            ctx.beginPath();
            ctx.moveTo(lastX, lastY);
            ctx.lineTo(x, y);
            ctx.stroke();
            
            [lastX, lastY] = [x, y];
        }
        
        function stopDrawing() {
            isDrawing = false;
        }
        
        function getCoordinates(e) {
            let clientX, clientY;
            
            if (e.type.includes('touch')) {
                clientX = e.touches[0].clientX;
                clientY = e.touches[0].clientY;
            } else {
                clientX = e.clientX;
                clientY = e.clientY;
            }
            
            const rect = canvas.getBoundingClientRect();
            return [
                clientX - rect.left,
                clientY - rect.top
            ];
        }
        
        // Event listeners for drawing
        canvas.addEventListener('mousedown', startDrawing);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', stopDrawing);
        canvas.addEventListener('mouseout', stopDrawing);
        
        // Touch events for mobile
        canvas.addEventListener('touchstart', function(e) {
            e.preventDefault();
            startDrawing(e);
        });
        canvas.addEventListener('touchmove', function(e) {
            e.preventDefault();
            draw(e);
        });
        canvas.addEventListener('touchend', stopDrawing);
        
        // Clear signature
        document.getElementById('clearSignature').addEventListener('click', function() {
            ctx.fillStyle = '#f8fafc';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
        });
        
        // Set current date
        const today = new Date();
        const formattedDate = today.toLocaleDateString('en-US', { 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
        });
        
        document.getElementById('dateField').value = formattedDate;
        
        // Font style buttons
        document.querySelectorAll('.font-style-btn').forEach(button => {
            button.addEventListener('click', function() {
                // Remove active class from all buttons
                document.querySelectorAll('.font-style-btn').forEach(btn => {
                    btn.classList.remove('active-font', 'bg-purple-100', 'border-purple-500');
                });
                
                // Add active class to clicked button
                this.classList.add('active-font', 'bg-purple-100', 'border-purple-500');
                
                const font = this.getAttribute('data-font');
                const input = document.getElementById('typedSignature');
                
                if (font === 'cursive') {
                    input.style.fontFamily = 'cursive';
                    input.style.fontStyle = 'italic';
                } else if (font === 'sans') {
                    input.style.fontFamily = 'sans-serif';
                    input.style.fontStyle = 'normal';
                } else if (font === 'serif') {
                    input.style.fontFamily = 'serif';
                    input.style.fontStyle = 'normal';
                }
            });
        });
        
        // Set cursive as default
        document.querySelector('.font-style-btn[data-font="cursive"]').click();
        
        // Draggable elements functionality
        const draggableElements = document.getElementById('draggableElements');
        const documentDropArea = document.getElementById('documentDropArea');
        const documentContent = document.getElementById('documentContent');
        let draggedElement = null;
        
        // Create a draggable signature from canvas
        document.getElementById('createSignature').addEventListener('click', function() {
            // Check if canvas has any drawing
            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            let isEmpty = true;
            
            for (let i = 3; i < imageData.data.length; i += 4) {
                if (imageData.data[i] !== 0) {
                    isEmpty = false;
                    break;
                }
            }
            
            if (isEmpty) {
                alert('Please draw a signature first');
                return;
            }
            
            const dataURL = canvas.toDataURL();
            createDraggableElement('signature', dataURL);
        });
        
        // Create a draggable typed signature
        document.getElementById('createTypedSignature').addEventListener('click', function() {
            const signatureText = document.getElementById('typedSignature').value;
            
            if (!signatureText) {
                alert('Please enter your name');
                return;
            }
            
            createDraggableElement('typed-signature', signatureText);
        });
        
        // Create a draggable date
        document.getElementById('createDate').addEventListener('click', function() {
            createDraggableElement('date', formattedDate);
        });
        
        // Create a draggable element
        function createDraggableElement(type, content) {
            const element = document.createElement('div');
            element.className = 'draggable bg-white p-3 rounded-lg border border-gray-300 shadow-sm';
            element.setAttribute('data-type', type);
            element.draggable = true;
            
            if (type === 'signature') {
                element.innerHTML = `
                    <div class="flex items-center">
                        <img src="${content}" alt="Signature" class="h-8 mr-2">
                        <span class="text-sm font-medium">Signature</span>
                    </div>
                `;
            } else if (type === 'typed-signature') {
                const fontFamily = document.getElementById('typedSignature').style.fontFamily || 'cursive';
                const fontStyle = document.getElementById('typedSignature').style.fontStyle || 'italic';
                
                element.innerHTML = `
                    <div class="flex items-center">
                        <div class="h-8 flex items-center justify-center mr-2" style="font-family: ${fontFamily}; font-style: ${fontStyle};">
                            ${content}
                        </div>
                        <span class="text-sm font-medium">Typed Signature</span>
                    </div>
                `;
            } else if (type === 'date') {
                element.innerHTML = `
                    <div class="flex items-center">
                        <div class="h-8 flex items-center justify-center mr-2 font-medium">
                            ${content}
                        </div>
                        <span class="text-sm font-medium">Date</span>
                    </div>
                `;
            }
            
            // Add drag event listeners
            element.addEventListener('dragstart', handleDragStart);
            element.addEventListener('dragend', handleDragEnd);
            
            draggableElements.appendChild(element);
        }
        
        // Handle drag start
        function handleDragStart(e) {
            draggedElement = this.cloneNode(true);
            draggedElement.classList.add('dragging', 'transparent-drag');
            
            // Store the type and content
            const type = this.getAttribute('data-type');
            draggedElement.setAttribute('data-type', type);
            
            if (type === 'signature') {
                const img = this.querySelector('img');
                draggedElement.innerHTML = `<img src="${img.src}" alt="Signature" class="h-12">`;
            } else if (type === 'typed-signature') {
                const text = this.querySelector('div').textContent;
                const fontFamily = document.getElementById('typedSignature').style.fontFamily || 'cursive';
                const fontStyle = document.getElementById('typedSignature').style.fontStyle || 'italic';
                
                draggedElement.innerHTML = `
                    <div style="font-family: ${fontFamily}; font-style: ${fontStyle}; font-size: 1.2rem;">
                        ${text}
                    </div>
                `;
            } else if (type === 'date') {
                const date = this.querySelector('div').textContent;
                draggedElement.innerHTML = `
                    <div class="font-medium text-lg">
                        ${date}
                    </div>
                `;
            }
            
            draggedElement.style.position = 'absolute';
            draggedElement.style.zIndex = '1000';
            draggedElement.style.backgroundColor = 'transparent';
            document.body.appendChild(draggedElement);
            
            // Set drag image
            e.dataTransfer.setDragImage(draggedElement, 0, 0);
            e.dataTransfer.effectAllowed = 'move';
        }
        
        // Handle drag end
        function handleDragEnd(e) {
            if (draggedElement) {
                document.body.removeChild(draggedElement);
                draggedElement = null;
            }
        }
        
        // Set up drop area
        documentDropArea.addEventListener('dragover', function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
        });
        
        documentDropArea.addEventListener('drop', function(e) {
            e.preventDefault();
            
            if (!draggedElement) return;
            
            const rect = documentDropArea.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            const droppedItem = document.createElement('div');
            droppedItem.className = 'dropped-item transparent-drag';
            droppedItem.style.left = `${x}px`;
            droppedItem.style.top = `${y}px`;
            
            const type = draggedElement.getAttribute('data-type');
            
            if (type === 'signature') {
                droppedItem.classList.add('dropped-signature');
                droppedItem.innerHTML = `
                    ${draggedElement.innerHTML}
                    <div class="delete-btn">
                        <i class="fas fa-times"></i>
                    </div>
                `;
            } else if (type === 'typed-signature') {
                droppedItem.classList.add('dropped-signature');
                droppedItem.innerHTML = `
                    ${draggedElement.innerHTML}
                    <div class="delete-btn">
                        <i class="fas fa-times"></i>
                    </div>
                `;
            } else if (type === 'date') {
                droppedItem.classList.add('dropped-date');
                droppedItem.innerHTML = `
                    ${draggedElement.innerHTML}
                    <div class="delete-btn">
                        <i class="fas fa-times"></i>
                    </div>
                `;
            }
            
            // Make dropped items draggable
            makeDroppedItemDraggable(droppedItem);
            
            documentContent.appendChild(droppedItem);
        });
        
        // Make dropped items draggable
        function makeDroppedItemDraggable(element) {
            let isDragging = false;
            let offsetX, offsetY;
            
            element.addEventListener('mousedown', function(e) {
                if (e.target.classList.contains('delete-btn')) return;
                
                isDragging = true;
                offsetX = e.offsetX;
                offsetY = e.offsetY;
                element.style.zIndex = '1000';
                document.body.style.userSelect = 'none';
            });
            
            document.addEventListener('mousemove', function(e) {
                if (!isDragging) return;
                
                const rect = documentDropArea.getBoundingClientRect();
                const x = e.clientX - rect.left - offsetX;
                const y = e.clientY - rect.top - offsetY;
                
                // Constrain to document area
                const maxX = documentContent.offsetWidth - element.offsetWidth;
                const maxY = documentContent.offsetHeight - element.offsetHeight;
                
                element.style.left = `${Math.max(0, Math.min(x, maxX))}px`;
                element.style.top = `${Math.max(0, Math.min(y, maxY))}px`;
            });
            
            document.addEventListener('mouseup', function() {
                isDragging = false;
                element.style.zIndex = '';
                document.body.style.userSelect = '';
            });
            
            // Delete button functionality
            const deleteBtn = element.querySelector('.delete-btn');
            deleteBtn.addEventListener('click', function() {
                element.remove();
            });
        }
        
        // Reset document
        document.getElementById('resetDocument').addEventListener('click', function() {
            const droppedItems = documentContent.querySelectorAll('.dropped-item');
            droppedItems.forEach(item => item.remove());
            
            draggableElements.innerHTML = '';
            
            // Clear the canvas
            ctx.fillStyle = '#f8fafc';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
        });
        
        // Download functionality
        const downloadModal = document.getElementById('downloadModal');
        const closeModal = document.getElementById('closeModal');
        const cancelDownload = document.getElementById('cancelDownload');
        const confirmDownload = document.getElementById('confirmDownload');
        const downloadOptions = document.querySelectorAll('.download-option');
        const loadingSpinner = document.getElementById('loadingSpinner');
        
        let selectedFormat = 'pdf';
        
        // Download modal handlers
        document.getElementById('downloadDocument').addEventListener('click', function() {
            const droppedItems = documentContent.querySelectorAll('.dropped-item');
            
            if (droppedItems.length === 0) {
                alert('Please add at least one signature or date before downloading');
                return;
            }
            
            downloadModal.classList.add('active');
        });
        
        closeModal.addEventListener('click', function() {
            downloadModal.classList.remove('active');
        });
        
        cancelDownload.addEventListener('click', function() {
            downloadModal.classList.remove('active');
        });
        
        // Download option selection
        downloadOptions.forEach(option => {
            option.addEventListener('click', function() {
                downloadOptions.forEach(opt => opt.classList.remove('selected'));
                this.classList.add('selected');
                selectedFormat = this.getAttribute('data-format');
            });
        });
        
        // Confirm download
        confirmDownload.addEventListener('click', function() {
            // Show loading spinner
            document.getElementById('downloadOptions').style.display = 'none';
            loadingSpinner.style.display = 'block';
            
            // Generate and download the document
            setTimeout(() => {
                if (selectedFormat === 'pdf') {
                    downloadAsPDF();
                } else {
                    downloadAsImage();
                }
                
                // Hide modal and reset UI
                downloadModal.classList.remove('active');
                document.getElementById('downloadOptions').style.display = 'block';
                loadingSpinner.style.display = 'none';
            }, 1500);
        });
        
        // Download as PDF function
        function downloadAsPDF() {
            // In a real implementation, you would use jsPDF and html2canvas
            // This is a simplified version for demonstration
            
            // Create a temporary element to capture
            const tempElement = documentContent.cloneNode(true);
            
            // Remove delete buttons for the PDF
            const deleteButtons = tempElement.querySelectorAll('.delete-btn');
            deleteButtons.forEach(btn => btn.remove());
            
            // Use html2canvas to capture the document as an image
            html2canvas(tempElement, {
                scale: 2,
                useCORS: true,
                logging: false
            }).then(canvas => {
                // Create PDF
                const { jsPDF } = window.jspdf;
                const pdf = new jsPDF('p', 'mm', 'a4');
                
                const imgData = canvas.toDataURL('image/png');
                const pdfWidth = pdf.internal.pageSize.getWidth();
                const pdfHeight = pdf.internal.pageSize.getHeight();
                const imgWidth = canvas.width;
                const imgHeight = canvas.height;
                const ratio = Math.min(pdfWidth / imgWidth, pdfHeight / imgHeight);
                const imgX = (pdfWidth - imgWidth * ratio) / 2;
                const imgY = 10;
                
                pdf.addImage(imgData, 'PNG', imgX, imgY, imgWidth * ratio, imgHeight * ratio);
                pdf.save('signed-document.pdf');
                
                // Show success message
                showDownloadSuccess('PDF');
            });
        }
        
        // Download as Image function
        function downloadAsImage() {
            // Create a temporary element to capture
            const tempElement = documentContent.cloneNode(true);
            
            // Remove delete buttons for the image
            const deleteButtons = tempElement.querySelectorAll('.delete-btn');
            deleteButtons.forEach(btn => btn.remove());
            
            // Use html2canvas to capture the document as an image
            html2canvas(tempElement, {
                scale: 2,
                useCORS: true,
                logging: false
            }).then(canvas => {
                const link = document.createElement('a');
                link.download = 'signed-document.png';
                link.href = canvas.toDataURL('image/png');
                link.click();
                
                // Show success message
                showDownloadSuccess('PNG image');
            });
        }
        
        // Show download success message
        function showDownloadSuccess(format) {
            // Create a temporary success message
            const successMsg = document.createElement('div');
            successMsg.className = 'fixed bottom-4 right-4 bg-green-500 text-white px-4 py-3 rounded-lg shadow-lg z-50';
            successMsg.innerHTML = `
                <div class="flex items-center">
                    <i class="fas fa-check-circle mr-2"></i>
                    <span>Document downloaded as ${format} successfully!</span>
                </div>
            `;
            
            document.body.appendChild(successMsg);
            
            // Remove after 3 seconds
            setTimeout(() => {
                successMsg.remove();
            }, 3000);
        }
    </script>
