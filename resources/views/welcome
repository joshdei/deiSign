<script>
// PDF Upload Functionality
document.addEventListener('DOMContentLoaded', function() {
    const uploadArea = document.getElementById('uploadArea');
    const pdfUpload = document.getElementById('pdfUpload');
    const defaultDocument = document.getElementById('defaultDocument');
    const pdfDocument = document.getElementById('pdfDocument');
    const documentDropArea = document.getElementById('documentDropArea');

    // Click to upload
    uploadArea.addEventListener('click', function() {
        pdfUpload.click();
    });

    // Drag and drop functionality
    uploadArea.addEventListener('dragover', function(e) {
        e.preventDefault();
        uploadArea.classList.add('border-purple-400', 'bg-purple-50');
    });

    uploadArea.addEventListener('dragleave', function() {
        uploadArea.classList.remove('border-purple-400', 'bg-purple-50');
    });

    uploadArea.addEventListener('drop', function(e) {
        e.preventDefault();
        uploadArea.classList.remove('border-purple-400', 'bg-purple-50');
        
        const files = e.dataTransfer.files;
        if (files.length > 0 && files[0].type === 'application/pdf') {
            handlePDFUpload(files[0]);
        } else {
            alert('Please upload a PDF file');
        }
    });

    // File input change
    pdfUpload.addEventListener('change', function(e) {
        if (e.target.files.length > 0) {
            handlePDFUpload(e.target.files[0]);
        }
    });

    function handlePDFUpload(file) {
        if (file.size > 10 * 1024 * 1024) { // 10MB limit
            alert('File size must be less than 10MB');
            return;
        }

        // Show loading state
        uploadArea.innerHTML = `
            <div class="flex flex-col items-center">
                <div class="w-8 h-8 border-2 border-purple-600 border-t-transparent rounded-full animate-spin mb-2"></div>
                <p class="text-gray-600">Processing PDF...</p>
            </div>
        `;

        // Simulate PDF processing (in a real app, you would use PDF.js or similar)
        setTimeout(() => {
            // Display the uploaded PDF
            displayPDFPreview(file.name);
            
            // Reset upload area
            uploadArea.innerHTML = `
                <i class="fas fa-file-pdf text-3xl text-green-500 mb-2"></i>
                <p class="text-gray-600 mb-1">PDF Uploaded Successfully!</p>
                <p class="text-green-600 text-sm">${file.name}</p>
                <button class="mt-2 text-purple-600 text-sm hover:text-purple-700" onclick="uploadNewPDF()">
                    Upload different file
                </button>
            `;
        }, 1500);
    }

    // Function to display PDF preview
    function displayPDFPreview(filename) {
        // Hide default document, show PDF document
        defaultDocument.classList.add('hidden');
        pdfDocument.classList.remove('hidden');
        
        // In a real implementation, you would use PDF.js to render the PDF
        // For this demo, we'll create a simulated PDF view
        pdfDocument.innerHTML = `
            <div class="p-6">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-lg font-semibold text-gray-800">${filename}</h3>
                    <span class="text-sm text-gray-500">Page 1 of 1</span>
                </div>
                
                <!-- Simulated PDF Page -->
                <div class="bg-white border border-gray-200 rounded shadow-sm p-8 mx-auto" style="max-width: 800px; min-height: 800px;">
                    <div class="text-center mb-8">
                        <h1 class="text-2xl font-bold text-gray-800">UPLOADED DOCUMENT</h1>
                        <p class="text-gray-600 mt-2">This is a preview of your uploaded PDF</p>
                    </div>
                    
                    <div class="mb-6">
                        <h2 class="text-lg font-semibold text-gray-800 mb-2">Document Information</h2>
                        <p class="text-gray-700 mb-4">
                            This document was uploaded for digital signing. You can now add your signature and date to complete the signing process.
                        </p>
                        <div class="grid grid-cols-2 gap-4 mt-4">
                            <div>
                                <p class="text-sm text-gray-600">File Name:</p>
                                <p class="font-medium">${filename}</p>
                            </div>
                            <div>
                                <p class="text-sm text-gray-600">Upload Date:</p>
                                <p class="font-medium">${new Date().toLocaleDateString()}</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Signature areas for the uploaded document -->
                    <div class="mt-12 pt-8 border-t border-gray-300">
                        <div class="flex flex-col md:flex-row justify-between">
                            <div class="mb-6 md:mb-0 md:w-1/2">
                                <p class="text-gray-700 mb-2"><strong>Signature</strong></p>
                                <div class="signature-pad-container h-24 border border-gray-300 rounded bg-white relative">
                                    <div class="signature-line"></div>
                                    <div class="absolute inset-0 flex items-center justify-center p-4">
                                        <p class="text-gray-500 text-sm">Drag signature here</p>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="md:w-1/2">
                                <p class="text-gray-700 mb-2"><strong>Date</strong></p>
                                <div class="date-field bg-white p-2 border border-gray-300 rounded text-center">
                                    <span class="text-gray-500">Drag date here</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        `;

        // Make the new document area droppable
        const newDocumentContent = pdfDocument.querySelector('.bg-white.border');
        if (newDocumentContent) {
            // Re-initialize drop functionality for the new document
            initializeDropArea(newDocumentContent);
        }
    }

    // Function to upload a new PDF
    window.uploadNewPDF = function() {
        // Reset to initial state
        uploadArea.innerHTML = `
            <i class="fas fa-file-pdf text-3xl text-red-500 mb-2"></i>
            <p class="text-gray-600 mb-1">Click to upload PDF</p>
            <p class="text-gray-500 text-sm">or drag and drop your file here</p>
            <input type="file" id="pdfUpload" accept=".pdf" class="hidden">
        `;
        
        // Show default document, hide PDF document
        defaultDocument.classList.remove('hidden');
        pdfDocument.classList.add('hidden');
        
        // Re-attach event listeners
        const newPdfUpload = document.getElementById('pdfUpload');
        newPdfUpload.addEventListener('change', function(e) {
            if (e.target.files.length > 0) {
                handlePDFUpload(e.target.files[0]);
            }
        });
    };

    // Initialize drop area for signatures
    function initializeDropArea(area) {
        area.addEventListener('dragover', function(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
        });

        area.addEventListener('drop', function(e) {
            e.preventDefault();
            
            if (!window.draggedElement) return;
            
            const rect = area.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            const droppedItem = document.createElement('div');
            droppedItem.className = 'dropped-item transparent-drag';
            droppedItem.style.left = `${x}px`;
            droppedItem.style.top = `${y}px`;
            
            const type = window.draggedElement.getAttribute('data-type');
            
            if (type === 'signature') {
                droppedItem.classList.add('dropped-signature');
                droppedItem.innerHTML = `
                    ${window.draggedElement.innerHTML}
                    <div class="delete-btn">
                        <i class="fas fa-times"></i>
                    </div>
                `;
            } else if (type === 'typed-signature') {
                droppedItem.classList.add('dropped-signature');
                droppedItem.innerHTML = `
                    ${window.draggedElement.innerHTML}
                    <div class="delete-btn">
                        <i class="fas fa-times"></i>
                    </div>
                `;
            } else if (type === 'date') {
                droppedItem.classList.add('dropped-date');
                droppedItem.innerHTML = `
                    ${window.draggedElement.innerHTML}
                    <div class="delete-btn">
                        <i class="fas fa-times"></i>
                    </div>
                `;
            }
            
            // Make dropped items draggable
            makeDroppedItemDraggable(droppedItem);
            area.appendChild(droppedItem);
        });
    }

    // Initialize the default drop area
    initializeDropArea(documentDropArea);
});

// Make sure to update the existing makeDroppedItemDraggable function to work with the new structure
function makeDroppedItemDraggable(element) {
    let isDragging = false;
    let offsetX, offsetY;
    
    element.addEventListener('mousedown', function(e) {
        if (e.target.classList.contains('delete-btn')) return;
        
        isDragging = true;
        offsetX = e.offsetX;
        offsetY = e.offsetY;
        element.style.zIndex = '1000';
        document.body.style.userSelect = 'none';
    });
    
    document.addEventListener('mousemove', function(e) {
        if (!isDragging) return;
        
        const parent = element.parentElement;
        const rect = parent.getBoundingClientRect();
        const x = e.clientX - rect.left - offsetX;
        const y = e.clientY - rect.top - offsetY;
        
        // Constrain to parent area
        const maxX = parent.offsetWidth - element.offsetWidth;
        const maxY = parent.offsetHeight - element.offsetHeight;
        
        element.style.left = `${Math.max(0, Math.min(x, maxX))}px`;
        element.style.top = `${Math.max(0, Math.min(y, maxY))}px`;
    });
    
    document.addEventListener('mouseup', function() {
        isDragging = false;
        element.style.zIndex = '';
        document.body.style.userSelect = '';
    });
    
    // Delete button functionality
    const deleteBtn = element.querySelector('.delete-btn');
    deleteBtn.addEventListener('click', function() {
        element.remove();
    });
}
</script>

